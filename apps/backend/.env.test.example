NODE_ENV=test
PORT=3002

# Test Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/the_draw_test
DATABASE_DIRECT_URL=postgresql://postgres:postgres@localhost:5432/the_draw_test

# Connection Pool Settings (smaller for testing)
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=5
DATABASE_POOL_TIMEOUT=10000

# SSL Configuration
DATABASE_SSL=false

# Redis Configuration
REDIS_URL=redis://localhost:6379/1

# JWT Configuration
JWT_SECRET=test-jwt-secret-key
JWT_EXPIRES_IN=1h

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Test Admin Account
ADMIN_DEFAULT_USER=testadmin
ADMIN_DEFAULT_PASSWORD=testpassword

# Application URLs
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3002