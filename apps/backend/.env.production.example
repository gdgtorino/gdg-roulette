NODE_ENV=production
PORT=3001

# Production Database Configuration
# NOTE: Replace with your actual production database URL
DATABASE_URL=postgresql://username:password@host:port/the_draw_prod
DATABASE_DIRECT_URL=postgresql://username:password@host:port/the_draw_prod

# Connection Pool Settings (optimized for production)
DATABASE_POOL_MIN=10
DATABASE_POOL_MAX=50
DATABASE_POOL_TIMEOUT=60000

# SSL Configuration (required for production)
DATABASE_SSL=true

# Redis Configuration
REDIS_URL=redis://prod-redis-host:6379

# JWT Configuration (use strong secret in production)
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_KEY
JWT_EXPIRES_IN=24h

# CORS Configuration (restrict to your domain)
CORS_ORIGIN=https://your-production-domain.com

# Production Admin Account
ADMIN_DEFAULT_USER=admin
ADMIN_DEFAULT_PASSWORD=CHANGE_IN_PRODUCTION

# Application URLs
APP_BASE_URL=https://your-production-domain.com
API_BASE_URL=https://api.your-production-domain.com