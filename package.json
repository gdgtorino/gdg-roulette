{
  "name": "the-draw",
  "version": "1.0.0",
  "description": "Lottery/raffle management system",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "yarn workspaces foreach -p run dev",
    "build": "yarn workspaces foreach -t run build",
    "start": "yarn workspaces foreach -p run start",
    "clean": "yarn workspaces foreach run clean",
    "test": "yarn workspaces foreach run test",
    "lint": "yarn workspaces foreach run lint",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:staging": "docker-compose -f docker-compose.yml -f docker-compose.staging.yml up -d",
    "docker:production": "docker-compose -f docker-compose.yml -f docker-compose.production.yml up -d",
    "deploy:staging": "./scripts/deploy.sh staging",
    "deploy:production": "./scripts/deploy.sh production",
    "deploy:staging:force": "./scripts/deploy.sh staging --force",
    "deploy:production:force": "./scripts/deploy.sh production --force",
    "health:check": "yarn workspaces foreach run health:check",
    "security:audit": "yarn audit --level moderate",
    "db:migrate": "yarn workspace @the-draw/backend db:migrate",
    "db:seed": "yarn workspace @the-draw/backend db:seed",
    "monitoring:up": "docker-compose -f docker-compose.yml -f docker-compose.staging.yml up -d prometheus grafana",
    "logs": "docker-compose logs -f",
    "logs:backend": "docker-compose logs -f backend",
    "logs:frontend": "docker-compose logs -f frontend"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "packageManager": "yarn@4.0.0"
}
