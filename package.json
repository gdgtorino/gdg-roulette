{
  "name": "the-draw",
  "version": "1.0.0",
  "description": "Lottery/raffle management system",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "yarn test:unit && yarn test:integration",
    "test:unit": "jest --passWithNoTests",
    "test:integration": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "yarn test:unit --ci --coverage --passWithNoTests && yarn test:integration --run && yarn test:e2e",
    "test:db": "NODE_ENV=test vitest run database/",
    "test:setup": "node -r ts-node/register database/test-setup.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:staging": "docker-compose -f docker-compose.yml -f docker-compose.staging.yml up -d",
    "docker:production": "docker-compose -f docker-compose.yml -f docker-compose.production.yml up -d",
    "deploy:staging": "./scripts/deploy.sh staging",
    "deploy:production": "./scripts/deploy.sh production",
    "health:check": "curl -f http://localhost:3000/api/health || exit 1",
    "security:audit": "yarn audit --level moderate",
    "monitoring:up": "docker-compose -f docker-compose.yml -f docker-compose.staging.yml up -d prometheus grafana",
    "logs": "docker-compose logs -f",
    "format": "prettier --write '**/**.ts|tsx|json|md'",
    "format:check": "prettier --check '**/**.tsx|ts|json|md'"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@t3-oss/env-nextjs": "^0.11.1",
    "@tanstack/react-query": "^5.59.16",
    "@trpc/client": "next",
    "@trpc/next": "next",
    "@trpc/react-query": "next",
    "@trpc/server": "next",
    "@types/bcryptjs": "^3.0.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/jsonwebtoken": "^9.0.10",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.2",
    "canvas-confetti": "^1.9.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.451.0",
    "next": "^14.2.14",
    "next-intl": "^4.3.8",
    "prisma": "^5.20.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "redis": "^5.8.2",
    "socket.io-client": "^4.8.1",
    "superjson": "^2.2.1",
    "tailwind-merge": "^2.5.3",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^13.0.0",
    "whatwg-fetch": "^3.6.20",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@jest/globals": "^30.1.2",
    "@playwright/test": "^1.55.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/babel__core": "^7",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/supertest": "^6.0.3",
    "autoprefixer": "^10.4.20",
    "babel-jest": "^30.1.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.14",
    "jest": "^30.1.3",
    "jest-environment-jsdom": "^30.1.2",
    "jest-junit": "^16.0.0",
    "msw": "^2.11.2",
    "playwright": "^1.55.0",
    "postcss": "^8.4.47",
    "supertest": "^7.1.4",
    "tailwindcss": "^3.4.13",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} database/seed.ts"
  },
  "packageManager": "yarn@4.0.0"
}
